# Copy to .env and fill in. Never commit .env.
#
# NOTE: with the docker-compose stack (make up) you normally do NOT need a
# .env at all - compose sets everything below. This file serves running the
# API outside docker, or overriding single values.
#
# PRODUCTION does not use a .env file: the ECS task definition injects the
# same variables (see "Production values" notes inline). Secrets never appear
# in either file - database credentials resolve from Secrets Manager at
# startup, and AWS calls use the task role (prod) or your `aws login`
# session (local).

# ---- AWS ----
AWS_REGION=us-east-1

# ---- Storage ----
# Production/default: the real S3 bucket, reached via your AWS session
S3_BUCKET=blueprintai-files-719287409727
# Offline mode only (make up-local): MinIO stand-in - uncomment all four
#S3_BUCKET=blueprintai-files
#S3_ENDPOINT_URL=http://localhost:9000
#S3_PUBLIC_ENDPOINT_URL=http://localhost:9000   # what the browser can reach
#S3_ACCESS_KEY=minioadmin
#S3_SECRET_KEY=minioadmin

# ---- Database ----
# Production/default: credentials fetched from Secrets Manager at startup
DATABASE_SECRET_ID=blueprintai/db
DATABASE_HOST=blueprintai-db.ccj86qq8ymmj.us-east-1.rds.amazonaws.com
# Offline mode: comment the two lines above and use the local Postgres
#DATABASE_SECRET_ID=
#DATABASE_URL=postgresql://postgres:postgres@localhost:5432/blueprintai

# ---- AI ----
# "bedrock" (default, needs AWS) or "ollama" (fully offline; switching
# embedding models requires re-ingesting the knowledge base)
AI_PROVIDER=bedrock
# Current Claude models on Bedrock REQUIRE the cross-region inference
# profile ID (us. prefix) - bare model IDs are rejected for on-demand.
BEDROCK_VISION_MODEL=us.anthropic.claude-opus-4-8
BEDROCK_TEXT_MODEL=us.anthropic.claude-opus-4-8
BEDROCK_EMBED_MODEL=amazon.titan-embed-text-v2:0
# Hybrid full-resolution OCR (degrades gracefully without Textract access)
TEXTRACT_ENABLED=true

# ---- Pipeline concurrency ----
#EMBED_CONCURRENCY=8
#VISION_PAGE_CONCURRENCY=2

# ---- Auth ----
# Optional deterministic first-run admin password; when unset, a random one
# is generated and printed ONCE in the backend logs.
#INITIAL_ADMIN_PASSWORD=

# ---- Ollama (offline AI mode only) ----
#OLLAMA_BASE_URL=http://localhost:11434
