# Copy to .env and fill in. Never commit .env.

# AWS
AWS_REGION=us-east-1
S3_BUCKET=blueprintai-files

# Bedrock model IDs (enable access in the Bedrock console first)
# Claude Opus 4.8 is the current recommended model; anthropic.claude-sonnet-5 is a cheaper option
BEDROCK_VISION_MODEL=anthropic.claude-opus-4-8
BEDROCK_TEXT_MODEL=anthropic.claude-opus-4-8
BEDROCK_EMBED_MODEL=amazon.titan-embed-text-v2:0

# Postgres (RDS + pgvector)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/blueprintai
